# AFL Tipping Agent - Environment Variables
# Copy this file to .env and fill in your API keys

# ========================================
# PRIMARY AI ENGINE (REQUIRED)
# ========================================
# Get your key at: https://console.anthropic.com/settings/keys
# Cost: ~$0.013 per round (~$0.30 for 24-round season)
# Add $5-10 credit to your account
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ========================================
# BETTING ODDS DATA (REQUIRED)
# ========================================
# Get your key at: https://the-odds-api.com/account
# Free tier: 500 requests/month (sufficient for season)
ODDS_API_KEY=your-odds-api-key-here

# ========================================
# BACKUP AI ENGINE (OPTIONAL BUT RECOMMENDED)
# ========================================
# Get your key at: https://console.groq.com
# Free tier available
# Used as fallback if primary AI fails
GROQ_API_KEY=gsk_your-groq-key-here

# ========================================
# NOTES
# ========================================
# - Never commit your .env file to git (it's in .gitignore)
# - Keep your API keys secure
# - Don't share your keys publicly
# - Rotate keys if they're compromised
# - Monitor your API usage/billing

# ========================================
# FOR STREAMLIT CLOUD DEPLOYMENT
# ========================================
# Don't use .env file on Streamlit Cloud
# Instead, add secrets in app settings using TOML format:
#
# ANTHROPIC_API_KEY = "sk-ant-api03-your-key-here"
# ODDS_API_KEY = "your-odds-api-key-here"
# GROQ_API_KEY = "gsk_your-groq-key-here"
